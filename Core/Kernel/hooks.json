{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CODEX_HOME=\"${CODEX_HOME:-$HOME/.codex}\"; python3 \"$CODEX_HOME/bin/hooks/session_start.py\"",
            "statusMessage": "sovereign: briefing inject",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CODEX_HOME=\"${CODEX_HOME:-$HOME/.codex}\"; python3 \"$CODEX_HOME/bin/hooks/user_prompt_submit.py\"",
            "statusMessage": "sovereign: lisan intent + journal surface",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "CODEX_HOME=\"${CODEX_HOME:-$HOME/.codex}\"; python3 \"$CODEX_HOME/bin/hooks/pre_tool_use.py\"",
            "statusMessage": "sovereign: log + golden path check",
            "timeout": 2
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "CODEX_HOME=\"${CODEX_HOME:-$HOME/.codex}\"; python3 \"$CODEX_HOME/bin/hooks/pre_tool_use.py\"",
            "statusMessage": "sovereign: permission passthrough",
            "timeout": 2
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "CODEX_HOME=\"${CODEX_HOME:-$HOME/.codex}\"; python3 \"$CODEX_HOME/bin/hooks/post_tool_use.py\"",
            "statusMessage": "sovereign: distill + reflect + output clean",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CODEX_HOME=\"${CODEX_HOME:-$HOME/.codex}\"; python3 \"$CODEX_HOME/bin/hooks/pre_compact.py\"",
            "statusMessage": "sovereign: persist key facts before compact",
            "timeout": 8
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CODEX_HOME=\"${CODEX_HOME:-$HOME/.codex}\"; python3 \"$CODEX_HOME/bin/hooks/post_compact.py\"",
            "statusMessage": "sovereign: capture compact summary",
            "timeout": 3
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CODEX_HOME=\"${CODEX_HOME:-$HOME/.codex}\"; python3 \"$CODEX_HOME/bin/hooks/subagent_start.py\"",
            "statusMessage": "sovereign: per-subagent preamble",
            "timeout": 3
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CODEX_HOME=\"${CODEX_HOME:-$HOME/.codex}\"; python3 \"$CODEX_HOME/bin/hooks/subagent_stop.py\"",
            "statusMessage": "sovereign: harvest subagent output",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CODEX_HOME=\"${CODEX_HOME:-$HOME/.codex}\"; python3 \"$CODEX_HOME/bin/hooks/stop.py\"",
            "statusMessage": "sovereign: final reflect + memory + golden path",
            "timeout": 8
          }
        ]
      }
    ]
  }
}
